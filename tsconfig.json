{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "target": "es2022",
    "outDir": "out",
    "rootDir": "./src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
